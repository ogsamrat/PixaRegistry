{
  "name": "pixa-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PIXA Registry — multichain, agent-native, verified discovery layer for machine-payable APIs (MVP).",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/ogsamrat/PixaRegistry.git"
  },
  "homepage": "https://github.com/ogsamrat/PixaRegistry#readme",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:api": "tsx src/index.ts",
    "build": "tsc && npm --prefix web run build",
    "build:server": "tsc",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "start": "node dist/index.js",
    "db:init": "tsx src/db/init.ts",
    "seed": "tsx src/seed.ts",
    "verify": "tsx src/cli.ts verify",
    "mcp": "tsx src/mcp/server.ts",
    "cli": "tsx src/cli.ts",
    "seller": "tsx src/test-seller/server.ts",
    "wallets": "tsx scripts/wallet-setup.ts",
    "e2e": "tsx scripts/e2e.ts"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "10.0.0-alpha.46",
    "@hono/node-server": "^1.14.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@vercel/blob": "^2.4.0",
    "@x402/avm": "~2.14.0",
    "@x402/core": "~2.14.0",
    "@x402/hono": "~2.14.0",
    "better-sqlite3": "^11.8.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.7.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.21",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
