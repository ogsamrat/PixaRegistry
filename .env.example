# PIXA Registry — environment template. Copy to .env and fill in.
# .env is gitignored; never commit wallet mnemonics.

# Buyer wallet mnemonic (Algorand testnet) — 24-word BIP39 HD phrase (Pera's
# newer wallets) or classic 25-word Algorand mnemonic; both are supported.
# When set, the registry can run REAL paid probes: it settles USDC on-chain
# and records the txid.
PIXA_BUYER_MNEMONIC=

# Max atomic amount (µUSDC) a single paid probe may spend. Default 100000 (0.1 USDC).
#PIXA_BUYER_MAX_ATOMIC=100000

# Test seller wallet (receives the test endpoints' payments).
PIXA_SELLER_MNEMONIC=
PIXA_SELLER_ADDRESS=

# Allow probing private/localhost targets (SSRF bypass) — local dev ONLY.
PIXA_ALLOW_PRIVATE=1

# Port for the local x402 test seller (npm run seller).
PIXA_TEST_SELLER_PORT=4910

# Core registry settings (see README):
#PIXA_DB=./data/pixa.db
#PORT=4055
#RATE_LIMIT_RPM=120
#PIXA_ADMIN_KEY=
#PIXA_TRUST_PROXY=
#PIXA_CORS_ORIGINS=*
